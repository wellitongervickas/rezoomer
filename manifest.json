{
  "manifest_version": 3,
  "name": "Rezoomer",
  "version": "0.1.0",
  "description": "AI-powered resume tailoring",
  "minimum_chrome_version": "116",

  "action": {
    "default_title": "Rezoomer – Toggle Side Panel"
  },

  "side_panel": {
    "default_path": "src/ui/sidepanel/index.html"
  },

  "options_page": "src/ui/options/index.html",

  "background": {
    "service_worker": "service-worker.js",
    "type": "classic"
  },

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://api.openai.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.openai.com;"
  }
}
